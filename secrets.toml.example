# Reference format for secrets.toml.

[secrets]
user_name = "nixos"
user_password = "changeme"
root_password = "changeme"
luks_password = "changeme"

[install]
# You generally do not need to think about this at all.
# Change it only when formatting a disk with Disko, for example via
# nixos-anywhere, disko-install, or another Disko-based install flow.
# For normal day-to-day nixos-rebuild usage on an already installed system,
# leave it alone.
disk_device = "/dev/vda"
